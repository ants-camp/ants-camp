# ================================================================
#  01~02. 대회 생성 / 게시  (운영자)
# ================================================================

# ---------------------------------------------------------------
# 01. 대회 생성  →  competition_id 자동 세팅
# ---------------------------------------------------------------
### @name createCompetition
POST {{gateway_base}}/api/competitions
Content-Type: application/json
Authorization: Bearer {{access_token_0}}

{
  "name": "2026 거래 테스트 대회",
  "type": "PERSONAL",
  "description": "유저1 vs 유저2 vs 유저3 수익률 대결",
  "firstSeed": 10000000,
  "registerStartAt": "2026-05-01T00:00:00",
  "registerEndAt": "2026-12-30T23:59:59",
  "competitionStartAt": "2026-12-31T00:00:00",
  "competitionEndAt": "2027-12-31T23:59:59",
  "minParticipants": 2,
  "maxParticipants": 100
}

> {%
    console.log("응답 상태:", response.status);
    console.log("응답 바디:", JSON.stringify(response.body));

    client.test("201 Created", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });

    if (response.body && response.body.data) {
        var id = response.body.data.competitionId;
        if (id) {
            client.global.set("competition_id", id);
            console.log("✅ competition_id 세팅:", id);
        }
    }
%}

# ---------------------------------------------------------------
# 01-1. 대회 생성 (대회서비스로 직접 요청)(운영자)
# ---------------------------------------------------------------
### @name createCompetition
POST localhost:8092/api/competitions
Content-Type: application/json
Authorization: Bearer {{access_token_0}}

{
  "name": "2026 거래 테스트 대회",
  "type": "PERSONAL",
  "description": "유저1 vs 유저2 vs 유저3 수익률 대결",
  "firstSeed": 10000000,
  "registerStartAt": "2026-05-01T00:00:00",
  "registerEndAt": "2026-12-30T23:59:59",
  "competitionStartAt": "2026-12-31T00:00:00",
  "competitionEndAt": "2027-12-31T23:59:59",
  "minParticipants": 2,
  "maxParticipants": 100
}


# ---------------------------------------------------------------
# 02. 대회 게시 (PREPARING → PUBLISHED)  (운영자)
# ---------------------------------------------------------------
### @name publishCompetition
POST {{gateway_base}}/api/competitions/{{competition_id}}/publications
Authorization: Bearer {{access_token_0}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    console.log("✅ 대회 게시 완료");
%}


# ================================================================
#  03~08. 대회 참가 신청 + 계좌 생성
# ================================================================

# ---------------------------------------------------------------
# 03. 유저1 대회 참가 신청  →  Kafka 이벤트로 계좌 자동 생성
# ---------------------------------------------------------------
### @name joinUser1
POST {{gateway_base}}/api/competitions/{{competition_id}}/participants
Content-Type: application/json
Authorization: Bearer {{access_token_1}}

> {%
    client.test("201 Created", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });
    console.log("✅ 유저1 참가 신청 완료 (Kafka → 자산서비스 계좌 자동 생성 대기 중)");
%}


# ---------------------------------------------------------------
# 03-a. 유저1 계좌 ID 조회  →  account_id_1 세팅
#   ⚠️ Kafka 비동기 처리 후 실행 — 계좌가 없으면 잠시 후 재시도
# ---------------------------------------------------------------
### @name fetchAccountUser1
GET {{gateway_base}}/api/accounts
Authorization: Bearer {{access_token_1}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    var accounts = response.body.data;
    if (accounts && accounts.length > 0) {
        client.global.set("account_id_1", accounts[0].accountId);
        console.log("✅ account_id_1 세팅:", accounts[0].accountId);
    } else {
        console.log("⚠️ 계좌가 아직 없음 — Kafka 처리 완료 후 재시도하세요.");
    }
%}


# ---------------------------------------------------------------
# 04. [폴백] 유저1 계좌 수동 생성  →  03-a 에서 계좌가 없을 때만 실행
# ---------------------------------------------------------------
### @name createAccountUser1
POST {{gateway_base}}/api/accounts
Content-Type: application/json
Authorization: Bearer {{access_token_1}}

{
  "userId": "{{user_id_1}}",
  "type": "COMPETITION",
  "initialAmount": 10000000,
  "competitionId": "{{competition_id}}"
}

> {%
    client.test("201 Created", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });
    var id = response.body.data && response.body.data.accountId;
    if (id) {
        client.global.set("account_id_1", id);
        console.log("✅ account_id_1 세팅 (수동):", id);
    }
%}


