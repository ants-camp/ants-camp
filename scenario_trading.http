GET {{gateway_base}}/api/holdings?accountId={{account_id_1}}
Authorization: Bearer {{access_token_1}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    console.log("보유 주식:", JSON.stringify(response.body, null, 2));
%}


# ================================================================
#  ── 1분 경과 ──  스케줄러가 총자산 재계산
#  아래 11~14번은 1분 후에 실행하세요.
# ================================================================

# ---------------------------------------------------------------
# 11. 유저1 자산 조회 (매수 후)
# ---------------------------------------------------------------
### @name getAssetUser1_after_buy
GET {{gateway_base}}/api/accounts/{{account_id_1}}
Authorization: Bearer {{access_token_1}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
