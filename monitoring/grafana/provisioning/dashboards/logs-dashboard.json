{
  "title": "Logs Dashboard",
  "uid": "logs-dashboard",
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 38,
  "links": [
    {
      "type": "link",
      "title": "← 서비스 대시보드",
      "url": "/d/service-dashboard/service-dashboard?var-job=${job}&var-search=${search}",
      "keepTime": true,
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up, job)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      },
      {
        "name": "search",
        "label": "로그 검색",
        "type": "textbox",
        "current": { "selected": false, "text": "", "value": "" },
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "로그",
      "type": "logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Ascending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"$job\"} |~ \"(?i)${search:regex}\"",
          "legendFormat": ""
        }
      ]
    }
  ]
}