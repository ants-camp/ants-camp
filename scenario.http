%}


# ================================================================
#  14~16. 순위 확인 / 대회 종료
# ================================================================

# ---------------------------------------------------------------
# 14. 대회 종료 전 순위 확인 (Redis 실시간)
# ---------------------------------------------------------------
### @name getRankingsBeforeFinish
GET {{ranking_base}}/api/rankings/competitions/{{competition_id}}?page=0&size=20

> {%
  client.test("200 OK", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  console.log("=== 대회 종료 전 순위 ===");
  if (Array.isArray(response.body)) {
    response.body.forEach(function(r) {
      console.log("  " + r.rank + "위", r.nickname, "| 총자산:", r.totalAsset, "| 수익률:", r.rateOfReturn + "%");
    });
  } else {
    console.log(JSON.stringify(response.body, null, 2));
  }
%}


# ---------------------------------------------------------------
# 15. 대회 종료 (ONGOING → FINISHED)
#  → Kafka: competition.finished 발행
#  ⚠️  종료 후 최종 순위 확정까지 수 초 소요될 수 있습니다 (비동기 처리).
#     16번 실행 전 잠시 대기하거나, [UTILITY] 수동 순위 확정을 실행하세요.
# ---------------------------------------------------------------
### @name finishCompetition
PATCH {{competition_base}}/api/competitions/{{competition_id}}/finish

> {%
  client.test("200 OK", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  client.test("status = FINISHED", function() {
    client.assert(response.body.status === "FINISHED", "status = " + response.body.status);
  });
  console.log("✅ 대회 종료. 상태:", response.body.status);
  console.log("[Kafka] competition.finished 발행 → 최종 자산 계산 및 순위 확정 트리거");
%}


# ---------------------------------------------------------------
# 16. 대회 종료 후 최종 순위 확인
# ---------------------------------------------------------------
### @name getRankingsAfterFinish
GET {{ranking_base}}/api/rankings/competitions/{{competition_id}}?page=0&size=20

> {%
  client.test("200 OK", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  console.log("=== 대회 최종 순위 ===");
  if (Array.isArray(response.body)) {
    response.body.forEach(function(r) {
      console.log("  " + r.rank + "위", r.nickname, "| 총자산:", r.totalAsset, "| 수익률:", r.rateOfReturn + "%");
    });
