# ---------------------------------------------------------------
# 09. 대회 시작 (PUBLISHED → ONGOING)
#  ⚠️  03~04 에서 유저1, 유저2가 신청 완료된 상태여야 합니다 (minParticipants=2).
# ---------------------------------------------------------------
### @name startCompetition
PATCH {{competition_base}}/api/competitions/{{competition_id}}/start

> {%
  client.test("200 OK", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  client.test("status = ONGOING", function() {
    client.assert(response.body.status === "ONGOING", "status = " + response.body.status);
  });
  console.log("✅ 대회 시작. 상태:", response.body.status);
%}


# ================================================================
#  10~13. 주식 거래 / 자산 조회
#
#  ⚠️  account_id_1 사전 세팅 필요
#      참가 신청(03번) 후 Kafka → Asset Service에서 계좌 자동 생성됩니다.
#      accountId는 아래 방법 중 하나로 확인하세요:
#
#      방법 A) DB 직접 조회
#        SELECT account_id FROM asset.accounts WHERE user_id = '11111111-...' AND type = 'COMPETITION';
#
#      방법 B) 하단 [UTILITY] 수동 계좌 생성 실행 후 응답의 accountId 사용
# ================================================================

# ---------------------------------------------------------------
# 10. 주식 차트 확인 (분봉)
#  → stock_code: 삼성전자 005930 (http-client.env.json 에서 변경 가능)
#  ⚠️  한국투자증권(KIS) API 연동 필요. 미연동 시 [UTILITY] KIS 토큰 발급 먼저 실행.
# ---------------------------------------------------------------
### @name getStockChart
GET {{trade_base}}/api/trades/minute-price?stock_code={{stock_code}}&date_time={{chart_datetime}}

> {%
  client.test("200 OK", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  console.log("종목코드:", "{{stock_code}}");
  console.log("분봉 데이터:", JSON.stringify(response.body, null, 2));
%}


# ---------------------------------------------------------------
# 11. 주식 매수
#  ⚠️  account_id_1 세팅 필요 (위 주석 참고)
# ---------------------------------------------------------------
### @name buyStock
POST {{asset_base}}/api/holdings/buy
Content-Type: application/json

{
  "accountId": "{{account_id_1}}",
  "stockCode": "{{stock_code}}",
  "stockAmount": 10,
  "buyPrice": 75000
}

> {%
  client.test("200 or 201", function() {
    client.assert(response.status === 200 || response.status === 201,
      "Expected 200/201, got " + response.status);
  });
  console.log("✅ 매수 완료:", "{{stock_code}}", "10주 @75,000원");
  console.log("응답:", JSON.stringify(response.body, null, 2));
%}


