### ============================================================
###  전체 시나리오 통합 테스트 (유저 서비스 제외)
###
###  서비스 포트 (로컬 직접 호출 기준)
###    competition-service → localhost:8092
###    asset-service       → localhost:8091
###    trade-service       → localhost:8093
###    ranking-service     → localhost:8094
###
###  ✅ 실행 순서 (위에서 아래로 순서대로 실행)
###    01. 대회 생성               → competition_id 자동 세팅
###    02. 대회 게시               → PUBLISHED
###    03. 유저1 대회 참가 신청   → Kafka: competition.registered
###    04. 유저2 대회 참가 신청   → Kafka: competition.registered
###    05. 유저3 대회 참가 신청   → Kafka: competition.registered
###    06. 참여자 목록 확인        → 유저1, 유저2, 유저3
###    07. 유저3 대회 참가 취소   → Kafka: competition.cancelled
###    08. 참여자 목록 확인        → 유저1, 유저2
###    09. 대회 시작               → ONGOING
###    10. 주식 차트 확인          → 분봉 데이터 (KIS API 연동 필요)
###    11. 주식 매수
###    12. 주식 매도
###    13. 자산 조회
###    14. 대회 종료 전 순위 확인
###    15. 대회 종료               → Kafka: competition.finished
###    16. 대회 종료 후 최종 순위 확인
###
###  ⚠️  사전 준비
###    1) http-client.env.json 의 환경(local)을 선택하세요.
###    2) 03~05 실행 후 Kafka → Asset Service에서 대회 계좌 자동 생성됩니다.
###       account_id_1 은 하단 [UTILITY] 수동 계좌 생성 또는 DB 조회로 세팅하세요.
### ============================================================


# ================================================================
#  01~02. 대회 생성 / 게시
# ================================================================

# ---------------------------------------------------------------
# 01. 대회 생성  →  competition_id 자동 세팅
# ---------------------------------------------------------------
### @name createCompetition
POST {{competition_base}}/api/competitions
Content-Type: application/json

{
  "name": "2026 봄 주식 모의투자 대회",
  "type": "PERSONAL",
  "description": "누가 가장 높은 수익률을 낼 수 있을까요?",
  "firstSeed": 10000000,
  "registerStartAt": "2026-01-01T00:00:00",
  "registerEndAt": "2026-12-30T23:59:59",
  "competitionStartAt": "2026-12-31T00:00:00",
  "competitionEndAt": "2027-12-31T23:59:59",
  "minParticipants": 2,
  "maxParticipants": 100
}

> {%
  client.test("201 Created", function() {
    client.assert(response.status === 201, "Expected 201, got " + response.status);
  });
  client.test("status = PREPARING", function() {
    client.assert(response.body.status === "PREPARING", "status = " + response.body.status);
  });
  if (response.body.competitionId) {
    client.global.set("competition_id", response.body.competitionId);
    console.log("✅ competition_id 세팅:", response.body.competitionId);
  }
%}


# ---------------------------------------------------------------
# 02. 대회 게시 (PREPARING → PUBLISHED)
#  → isReadable = true, 일반 유저에게 대회 공개
# ---------------------------------------------------------------
### @name publishCompetition
PATCH {{competition_base}}/api/competitions/{{competition_id}}/publish

> {%
  client.test("200 OK", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  client.test("isReadable = true", function() {
    client.assert(response.body.isReadable === true, "isReadable = " + response.body.isReadable);
  });
  console.log("✅ 대회 공개 완료. 상태:", response.body.status);
%}


# ================================================================
#  03~08. 대회 참가 신청 / 취소
# ================================================================

# ---------------------------------------------------------------
# 03. 유저1 대회 참가 신청  [Kafka: competition.registered 발행]
#  → Asset Service에서 유저1 대회 계좌 자동 생성
# ---------------------------------------------------------------
### @name joinUser1
POST {{competition_base}}/api/competitions/{{competition_id}}/participants
Content-Type: application/json

{
  "userId": "{{user_id_1}}",
  "nickname": "투자왕김철수"
}

> {%
  client.test("201 Created", function() {
    client.assert(response.status === 201, "Expected 201, got " + response.status);
  });
  console.log("[Kafka] competition.registered 발행 → 유저1 대회 계좌 생성 트리거");
%}


# ---------------------------------------------------------------
# 04. 유저2 대회 참가 신청  [Kafka: competition.registered 발행]
#  → Asset Service에서 유저2 대회 계좌 자동 생성
# ---------------------------------------------------------------
### @name joinUser2
POST {{competition_base}}/api/competitions/{{competition_id}}/participants
Content-Type: application/json

{
  "userId": "{{user_id_2}}",
  "nickname": "주식고수이영희"
}

> {%
  client.test("201 Created", function() {
    client.assert(response.status === 201, "Expected 201, got " + response.status);
  });
  console.log("[Kafka] competition.registered 발행 → 유저2 대회 계좌 생성 트리거");
%}


# ---------------------------------------------------------------
# 05. 유저3 대회 참가 신청  [Kafka: competition.registered 발행]
#  → Asset Service에서 유저3 대회 계좌 자동 생성
# ---------------------------------------------------------------
### @name joinUser3
POST {{competition_base}}/api/competitions/{{competition_id}}/participants
Content-Type: application/json

{
  "userId": "{{user_id_3}}",
  "nickname": "단타왕박민준"
}

> {%
  client.test("201 Created", function() {
    client.assert(response.status === 201, "Expected 201, got " + response.status);
  });
  console.log("[Kafka] competition.registered 발행 → 유저3 대회 계좌 생성 트리거");
%}


# ---------------------------------------------------------------
# 06. 참여자 목록 확인 — 유저1, 유저2, 유저3 모두 있어야 함
# ---------------------------------------------------------------
### @name getParticipantsBeforeCancel
GET {{competition_base}}/api/competitions/{{competition_id}}/participants

> {%
  client.test("200 OK", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  client.test("참여자 3명", function() {
    client.assert(response.body.length === 3, "참여자 수 = " + response.body.length + " (expected 3)");
  });
  console.log("참여자 수:", response.body.length);
  response.body.forEach(function(p, i) {
    console.log("  →", p.nickname, "(", p.userId, ")");
  });
%}


# ---------------------------------------------------------------
# 07. 유저3 대회 참가 취소  [Kafka: competition.cancelled 발행]
#  → Asset Service에서 유저3 대회 계좌 정리
# ---------------------------------------------------------------
### @name cancelUser3
DELETE {{competition_base}}/api/competitions/{{competition_id}}/participants
Content-Type: application/json

{
  "userId": "{{user_id_3}}",
  "nickname": "단타왕박민준"
}

> {%
  client.test("204 No Content", function() {
    client.assert(response.status === 204, "Expected 204, got " + response.status);
  });
  console.log("[Kafka] competition.cancelled 발행 → 유저3 대회 계좌 정리 트리거");
%}


# ---------------------------------------------------------------
# 08. 참여자 목록 확인 — 유저1, 유저2 만 있어야 함
# ---------------------------------------------------------------
### @name getParticipantsAfterCancel
GET {{competition_base}}/api/competitions/{{competition_id}}/participants

> {%
  client.test("200 OK", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  client.test("참여자 2명", function() {
    client.assert(response.body.length === 2, "참여자 수 = " + response.body.length + " (expected 2)");
  });
  console.log("참여자 수:", response.body.length);
  response.body.forEach(function(p, i) {
    console.log("  →", p.nickname, "(", p.userId, ")");
  });
%}


# ================================================================
#  09. 대회 시작
