# ---------------------------------------------------------------
# [U4] 수동 계좌 생성 (account_id 확보용)
#  → 참가 신청 후 Kafka로 자동 생성된 계좌의 ID를 모를 때 사용
#  → 응답의 accountId 를 http-client.env.json 의 account_id_1 에 복사하세요.
# ---------------------------------------------------------------
### @name createAccountManual
POST {{asset_base}}/api/accounts
Content-Type: application/json

{
  "userId": "{{user_id_1}}",
  "type": "COMPETITION",
  "initialAmount": 10000000
}

> {%
  client.test("201 Created", function() {
    client.assert(response.status === 201, "Expected 201, got " + response.status);
  });
  if (response.body) {
    client.global.set("account_id_1", response.body);
    console.log("✅ account_id_1 세팅:", response.body);
    console.log("⚠️  http-client.env.json 의 account_id_1 에도 복사해두세요.");
  }
%}


