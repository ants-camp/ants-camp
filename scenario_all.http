# ================================================================
#  00. 로그인 (토큰 + 유저 ID 발급)
# ================================================================

# ---------------------------------------------------------------
# 00-a. 운영자(user0) 로그인
# ---------------------------------------------------------------
### @name loginUser0
POST {{gateway_base}}/api/auth/login
Content-Type: application/json

{
  "email": "{{user0_email}}",
  "password": "{{user0_password}}"
}

> {%
    client.test("User0 Login Success", function() {
        client.assert(response.status === 200, "Login failed: " + response.status);
    });
    var data = response.body.data;
    client.global.set("access_token_0", data.accessToken);
    client.global.set("user_id_0", data.user.userId);
    console.log("✅ 운영자(user0) 로그인 완료 | userId:", data.user.userId);

    // ── 대회 시간 자동 계산 (현재 시각 기준 상대 시간) ───────────────────
    // 현재가 14:00 라면:
    //   registerEndAt = 14:03   (지금부터 3분 뒤까지 참가 신청 가능)
    //   competitionStartAt = 14:04
    //   competitionEndAt   = 14:18  (시작 후 14분 진행)
    // 시간 조정하려면 아래 분 단위 숫자만 바꾸면 됨.
    function pad(n) { return n < 10 ? "0" + n : "" + n; }
    function toLocalDateTime(d) {
        return d.getFullYear() + "-" + pad(d.getMonth() + 1) + "-" + pad(d.getDate())
             + "T" + pad(d.getHours()) + ":" + pad(d.getMinutes()) + ":" + pad(d.getSeconds());
    }
    var now = new Date();
    var REG_END_MIN = 3;     // 등록 마감: 지금 + 3분
    var START_MIN   = 4;     // 대회 시작: 지금 + 4분
    var END_MIN     = 18;    // 대회 종료: 지금 + 18분
    client.global.set("register_end_at",      toLocalDateTime(new Date(now.getTime() + REG_END_MIN * 60 * 1000)));
    client.global.set("competition_start_at", toLocalDateTime(new Date(now.getTime() + START_MIN   * 60 * 1000)));
    client.global.set("competition_end_at",   toLocalDateTime(new Date(now.getTime() + END_MIN     * 60 * 1000)));
    console.log("⏰ 대회 시간 자동 세팅:");
    console.log("   registerEndAt      =", client.global.get("register_end_at"));
    console.log("   competitionStartAt =", client.global.get("competition_start_at"));
    console.log("   competitionEndAt   =", client.global.get("competition_end_at"));
%}


