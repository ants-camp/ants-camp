# ---------------------------------------------------------------
# 14. 순위 확인 (매수 후)
# ---------------------------------------------------------------
### @name 해당 대회의 전체 순위 조회
GET {{gateway_base}}/api/rankings/competitions/{{competition_id}}?page=0&size=20
Authorization: Bearer {{access_token_1}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    console.log("=== 순위 (유저1 매수 후) ===");
    var data = (response.body && response.body.data) || response.body;
    if (Array.isArray(data)) {
        data.forEach(function(r) {
            console.log("  " + r.rank + "위 | userId:", r.userId, "| 총자산:", r.totalAsset);
        });
    } else {
        console.log(JSON.stringify(data, null, 2));
    }
%}
### @name 내 순위 조회
GET {{gateway_base}}/api/rankings/competitions/{{competition_id}}/me
Authorization: Bearer {{access_token_1}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    console.log("=== 내 순위 (유저1) ===");
    var me = (response.body && response.body.data) || response.body;
    console.log("  " + me.rank + "위 | userId:", me.userId, "| 총자산:", me.totalAsset);
%}

# ================================================================
#  15. 유저1 매도 (trade-service 경유)
#   흐름: POST /api/trades/order (side=SELL)
#     → trade-service: KIS 현재가 조회 → Trade(SELL) 저장
#     → Feign: assetClient.getStock(userId, AssetSellRequest)
#     → asset-service /api/holdings/sell
#         ├─ Holding.sell()       → 보유주식 수량 차감
#         └─ Account.deposit()    → 잔액 증가 (현재가 × 수량)
# ================================================================

### 시장가 매도 — 삼성전자 5주
POST {{gateway_base}}/api/trades/order
Content-Type: application/json
Authorization: Bearer {{access_token_1}}

{
  "stockCode":  "{{stock_code}}",
  "stockAmount": 5,
  "orderType": "MARKET",
  "side": "SELL",
  "limitPrice": null,
  "accountId": "{{account_id_1}}"
}

> {%
    client.test("200 or 201", function() {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200/201, got " + response.status);
    });
    var d = response.body.data;
    if (d) {
        console.log("✅ 유저1 시장가 매도 완료 — 삼성전자 5주 체결가=" + d.executedPrice
            + " 상태=" + d.status);
    } else {
        console.log("✅ 유저1 시장가 매도 완료 — 삼성전자 5주");
    }
    console.log("⏱  1분 경과 후 16~18번을 실행하면 tick 반영된 랭킹 확인 가능.");
%}

### 지정가 매도 (옵션) — limitPrice 이상일 때만 체결, 미충족 시 PENDING
# 지정가 매도 조건: 현재가 >= limitPrice 이면 체결.
# 삼전 현재가 약 27만원 → limitPrice 26만원으로 잡아 즉시 체결되도록 설계.
# 만약 시세가 더 떨어져 26만원 아래라면 PENDING으로 떨어지고,
# 스케줄러(LimitOrderScheduler)가 주기적으로 조건 만족 여부를 체크해 자동 체결한다.
POST {{gateway_base}}/api/trades/order
Content-Type: application/json
Authorization: Bearer {{access_token_1}}

{
  "stockCode":  "{{stock_code}}",
  "stockAmount": 1,
  "orderType": "LIMIT",
  "side": "SELL",
  "limitPrice": 260000.00,
  "accountId": "{{account_id_1}}"
}

> {%
    client.test("200 or 201", function() {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200/201, got " + response.status);
    });
    var d = response.body.data;
    if (d) {
        console.log("✅ 유저1 지정가 매도 요청 — 삼성전자 1주 limitPrice=260,000 상태=" + d.status);
    } else {
        console.log("✅ 유저1 지정가 매도 요청 완료");
    }
%}

# ---------------------------------------------------------------
# 16. 유저1 계좌잔액 조회 (매도 후 — 잔액이 늘어났는지 확인)
#   기대값: 매도 직전 잔액 + (5주 × 현재가). 현재가는 KIS API가 정함.
# ---------------------------------------------------------------
### @name 유저1 계좌잔액 조회 (매도 후)
GET {{gateway_base}}/api/accounts/{{account_id_1}}
Authorization: Bearer {{access_token_1}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    console.log("=== 유저1 자산 (매도 후) ===");
    console.log(JSON.stringify(response.body, null, 2));
%}

# ---------------------------------------------------------------
# 17. 유저1 보유 주식 조회 (매도 후 — 수량 감소 확인)
#   기대값:
#     - 매수: 시장가 10주 + 지정가 1주 = 11주
#     - 매도: 시장가 5주 + 지정가 1주(체결 시) = 6주 차감
#     ⇒ 지정가 매도가 즉시 체결됐다면: 11 − 6 = 5주 남음
#     ⇒ 지정가 매도가 PENDING이라면:  11 − 5 = 6주 남음 (지정가는 미체결 상태)
# ---------------------------------------------------------------
### @name 유저1 보유 주식 조회 (매도 후)
GET {{gateway_base}}/api/holdings?accountId={{account_id_1}}
Authorization: Bearer {{access_token_1}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    console.log("보유 주식 (매도 후):", JSON.stringify(response.body, null, 2));
%}

# ---------------------------------------------------------------
# 18. 순위 재확인 (매도 후 — 1분 경과 후 tick 반영 여부 확인)
# ---------------------------------------------------------------
### @name 순위 재조회 (매도 후)
GET {{gateway_base}}/api/rankings/competitions/{{competition_id}}?page=0&size=20
Authorization: Bearer {{access_token_1}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    console.log("=== 순위 (매도 후) ===");
    var data = (response.body && response.body.data) || response.body;
    if (Array.isArray(data)) {
        data.forEach(function(r) {
            console.log("  " + r.rank + "위 | userId:", r.userId, "| 총자산:", r.totalAsset);
        });
    } else {
        console.log(JSON.stringify(data, null, 2));
    }
%}

# ================================================================
#  20~21. 대회 종료 / 최종 순위  (운영자)
# ================================================================

# ---------------------------------------------------------------
# 20. 대회 종료 (ONGOING → FINISHED)
#  ⚠️  21번은 Kafka 비동기 처리 완료 후 실행 (수 초 소요)
# ---------------------------------------------------------------
### @name finishCompetition
POST {{gateway_base}}/api/competitions/{{competition_id}}/finishes
Authorization: Bearer {{access_token_0}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    console.log("✅ 대회 종료.");
    console.log("[Kafka] competition.finished → 최종 자산 계산 및 순위 확정 트리거");
%}

# ---------------------------------------------------------------
# 21. 최종 순위 조회 ( 위에서 본 전체 랭킹 조회와 같은 로직 )
# ---------------------------------------------------------------
### @name getFinalRankings
GET {{gateway_base}}/api/rankings/competitions/{{competition_id}}?page=0&size=20
Authorization: Bearer {{access_token_0}}

> {%
    client.test("200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    console.log("=== 최종 순위 ===");
    var data = (response.body && response.body.data) || response.body;
    if (Array.isArray(data)) {
        data.forEach(function(r) {
            console.log("  " + r.rank + "위 | userId:", r.userId, "| 총자산:", r.totalAsset);
        });
    } else {
        console.log(JSON.stringify(data, null, 2));
    }
%}
