# ================================================================
#  10. 유저1 매수
# ================================================================
### body => stockCode, stockAmout, orderType, side, limitPrice(double) => 지정가 주문시 필수 필드, 시장가는 null,
### header => X-ACCOUNT-ID (프론트에서 헤더로 넘겨준다)

### 시장가 매수
POST {{gateway_base}}/api/trades/order
content-type: application/json
Authorization: Bearer {{access_token_1}}

{
  "stockCode":  "{{stock_code}}",
  "stockAmount": 10,
  "orderType": "MARKET",
  "side": "BUY",
  "limitPrice": "",
  "accountId": "{{account_id_1}}"
}

> {%
    client.test("200 or 201", function() {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200/201, got " + response.status);
    });
    console.log("✅ 유저1 매수 완료 — 삼성전자 10주 체결총액: ", response.body.data.totalAmount);
    console.log("⏱  1분 경과 후 11~14번을 실행하세요.");
%}

### 지정가 매수 — 삼성전자 시장가 근처(약 27만원대)로 지정
POST {{gateway_base}}/api/trades/order
content-type: application/json
Authorization: Bearer {{access_token_1}}

{
  "stockCode":  "{{stock_code}}",
  "stockAmount": 1,
  "orderType": "LIMIT",
  "side": "BUY",
  "limitPrice": 280000.00,
  "accountId": "{{account_id_1}}"
}

> {%
    // 지정가 매수: 현재가 <= limitPrice 이면 체결.
    // 현재 삼전 시세 약 27만원 → limitPrice 28만원으로 잡아 즉시 체결되도록 설계.
    client.test("200 or 201", function() {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200/201, got " + response.status);
    });
    console.log("✅ 유저1 지정가 매수 완료 — 삼성전자 1주 (limitPrice=280,000)");
    console.log("⏱  1분 경과 후 11~14번을 실행하세요.");
%}

